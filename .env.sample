# Copy this file to .env and fill in your values
# Used for local development outside of minikube

# LocalStack
LOCALSTACK_ENDPOINT=http://localhost:4566
LOCALSTACK_AUTH_TOKEN=

# AWS (dummy values for LocalStack — not real credentials)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-west-1

# Terraform state (in LocalStack S3)
TERRAFORM_STATE_BUCKET=tf-state-provisioner
TERRAFORM_STATE_DYNAMODB_TABLE=terraform-lock
TERRAFORM_WORKING_DIR=./terraform/environments/dev

# Database
DATABASE_URL=sqlite:////data/provisioner.db

# ngrok (optional — used by deploy-minikube.sh)
NGROK_AUTHTOKEN=

